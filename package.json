{
    "name": "orks-app",
    "id": "uk.org.orks.app",
    "title": "ORKS App",
    "description": "ORKS mobile application.",
    "version": "6.2.3",
    "homepage": "https://orks.org.uk",
    "scripts": {
        "start": "webpack serve --progress --port 8000",
        "build": "NODE_ENV=production webpack",
        "build:production": "npm run clean && npm run build && npx cap sync && npm run build:resources",
        "build:resources": "mkdir -p resources && cp -R other/designs/android resources && cp -R other/designs/*.png resources && npx cordova-res ios --skip-config --resources resources --copy && npx cordova-res android --skip-config --resources resources --copy",
        "deploy": "cp other/demo.html build/ && URL=$(vercel --prod -t $VERCEL_TOKEN --yes -A ./other/vercel.json ./build) && CLEAN_URL=$(echo $URL | sed -r \"s/https:\\/\\/(.*)$/\\1/g\") && DEMO_URL=$(echo $CLEAN_URL | sed -r \"s/(.*\\-)[a-z0-9]+\\-flumens(\\.vercel\\.app)$/\\1${BITRISE_BUILD_NUMBER}\\2/g\") && envman add --key DEMO_URL --value \"https://$DEMO_URL\"",
        "deploy:production": "bitrise run ci",
        "clean": "rm -rf build resources",
        "check": "npx tsc --noEmit --skipLibCheck && npm run test:eslint",
        "test": "jest --silent --passWithNoTests",
        "test:watch": "jest --watchAll",
        "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand --watch test",
        "test:eslint": "eslint src --quiet && echo '\\033[37;42;1m PASS \\033[00m'",
        "test:e2e": "npx playwright test",
        "make:species": "cd src/common/data && tsx make.ts"
    },
    "dependencies": {
        "@capacitor-community/sqlite": "^8.0.0",
        "@capacitor/android": "8.1.0",
        "@capacitor/app": "8.0.1",
        "@capacitor/camera": "8.0.1",
        "@capacitor/core": "8.1.0",
        "@capacitor/device": "8.0.1",
        "@capacitor/filesystem": "8.1.2",
        "@capacitor/geolocation": "8.1.0",
        "@capacitor/haptics": "8.0.1",
        "@capacitor/ios": "8.1.0",
        "@capacitor/keyboard": "8.0.1",
        "@capacitor/network": "8.0.1",
        "@capacitor/share": "^8.0.1",
        "@capacitor/splash-screen": "8.0.1",
        "@capacitor/status-bar": "8.0.1",
        "@flumens/bigu": "0.4.1",
        "@flumens/ionic": "2.0.0-alpha.98",
        "@flumens/models": "0.26.0",
        "@flumens/tailwind": "0.39.0",
        "@flumens/utils": "^0.9.0",
        "@hookform/resolvers": "^5.2.2",
        "@ionic-native/core": "5.36.0",
        "@ionic/core": "^8.7.18",
        "@ionic/react": "^8.7.18",
        "@ionic/react-router": "^8.7.18",
        "@mapbox/sphericalmercator": "^2.0.2",
        "@sentry/browser": "10.40.0",
        "@turf/distance": "^7.3.4",
        "axios": "^1.13.5",
        "capacitor-blob-writer": "^1.1.19",
        "clsx": "2.1.1",
        "deep-diff": "1.0.2",
        "dompurify": "^3.3.1",
        "drizzle-orm": "^0.45.1",
        "i18next": "^25.8.13",
        "ionicons": "^8.0.13",
        "jeep-sqlite": "^2.8.0",
        "json-stable-stringify": "^1.3.0",
        "jwt-decode": "^4.0.0",
        "leaflet": "1.9.4",
        "lodash.camelcase": "^4.3.0",
        "lodash.mapkeys": "^4.6.0",
        "lodash.mergewith": "4.6.2",
        "mobx": "^6.15.0",
        "mobx-react": "9.2.1",
        "mobx-utils": "6.1.1",
        "mock-geolocation": "1.0.11",
        "proj4": "^2.20.2",
        "proj4leaflet": "^1.0.2",
        "react": "19.2.4",
        "react-aria-components": "^1.15.1",
        "react-autosuggest": "10.1.0",
        "react-dom": "19.2.4",
        "react-easy-crop": "^5.5.6",
        "react-hook-form": "^7.71.2",
        "react-i18next": "^16.5.4",
        "react-map-gl": "^8.1.0",
        "react-router": "5.3.4",
        "react-router-dom": "5.3.4",
        "react-window": "^2.2.7",
        "react-window-infinite-loader": "^2.0.1",
        "sql.js": "1.12.0",
        "swiper": "^12.1.2",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2",
        "wellknown": "^0.5.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/plugin-proposal-private-property-in-object": "7.21.11",
        "@babel/plugin-syntax-dynamic-import": "7.8.3",
        "@babel/plugin-transform-exponentiation-operator": "^7.28.6",
        "@babel/plugin-transform-runtime": "^7.29.0",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@capacitor/cli": "^8.1.0",
        "@flumens/eslint-config": "^3.0.2",
        "@flumens/prettier-config": "0.4.0",
        "@flumens/webpack-config": "^6.0.4",
        "@types/jest": "^30.0.0",
        "@types/leaflet": "^1.9.21",
        "@types/lodash.camelcase": "^4.3.9",
        "@types/lodash.mapkeys": "^4.6.9",
        "@types/lodash.mergewith": "^4.6.9",
        "@types/mapbox-gl": "3.4.1",
        "@types/node": "^25.7.0",
        "@types/proj4": "^2.19.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-router": "^5.1.20",
        "@types/react-router-dom": "5.3.3",
        "@types/react-window": "^2.0.0",
        "@types/react-window-infinite-loader": "^2.0.0",
        "babel-jest": "^30.2.0",
        "babel-plugin-module-resolver": "^5.0.2",
        "copy-webpack-plugin": "^13.0.1",
        "cordova-res": "^0.15.4",
        "dotenv": "^17.3.1",
        "eslint": "^9.39.2",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "jest-transform-stub": "2.0.0",
        "sinon": "^14.0.0",
        "tailwindcss": "^4.2.1",
        "tslib": "^2.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vercel": "^50.23.2",
        "webpack": "^5.105.2",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.3"
    },
    "browserslist": [
        "ChromeAndroid >= 89",
        "iOS >= 15"
    ],
    "engines": {
        "node": ">=20",
        "npm": ">=10"
    },
    "author": {
        "name": "Flumens",
        "email": "enquiries@flumens.io",
        "url": "https://flumens.io"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ERCCIS/orks-app"
    },
    "bugs": {
        "url": "https://github.com/ERCCIS/orks-app/issues"
    },
    "licenses": [
        {
            "type": "GNU GPL v3",
            "url": "http://www.gnu.org/licenses/gpl.html"
        }
    ],
    "keywords": [
        "orks",
        "irecord",
        "biological",
        "recording",
        "mobile",
        "app",
        "offline",
        "ukceh",
        "brc"
    ],
    "babel": {
        "presets": [
            [
                "@babel/react",
                {
                    "runtime": "automatic"
                }
            ],
            [
                "@babel/env",
                {
                    "loose": true,
                    "modules": "commonjs",
                    "corejs": "3.22",
                    "useBuiltIns": "usage"
                }
            ],
            [
                "@babel/typescript",
                {
                    "allowDeclareFields": true
                }
            ]
        ],
        "plugins": [
            [
                "@babel/transform-runtime",
                {
                    "regenerator": true
                }
            ],
            [
                "module-resolver",
                {
                    "root": [
                        "./src"
                    ],
                    "alias": {
                        "@flumens$": "./src/common/flumens",
                        "common": "./src/common",
                        "helpers": "./src/common/helpers",
                        "models": "./src/common/models",
                        "Components": "./src/common/Components"
                    }
                }
            ],
            [
                "@babel/proposal-private-property-in-object",
                {
                    "loose": true
                }
            ],
            "@babel/transform-exponentiation-operator",
            "@babel/syntax-dynamic-import"
        ]
    },
    "prettier": "@flumens/prettier-config",
    "jest": {
        "testEnvironment": "jsdom",
        "transform": {
            "^.+\\.(t|j)sx?$": [
                "babel-jest",
                {
                    "presets": [
                        "@babel/env"
                    ]
                }
            ]
        },
        "testRegex": "src.*((\\.|/*.)(test))\\.(t|j)s?$",
        "moduleNameMapper": {
            "^.+.(css|style|less|sass|scss|svg|png|jpg|ttf|woff|woff2)$": "jest-transform-stub",
            "ionicons": "jest-transform-stub",
            "ionic-native": "jest-transform-stub",
            "swiper": "jest-transform-stub"
        },
        "moduleDirectories": [
            "node_modules",
            "components",
            "src"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/test/setupTests.js"
        ],
        "transformIgnorePatterns": [
            "node_modules/(?!@ionic|@stencil|ionicons)"
        ]
    }
}
